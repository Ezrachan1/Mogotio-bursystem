# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/constituency_bursary
DB_NAME=constituency_bursary
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Email Configuration
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=25
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@outlook.com
EMAIL_HOST_PASSWORD=your-password
DEFAULT_FROM_EMAIL=your-email@outlook.com

# SMS Configuration (Africa's Talking)
AFRICASTALKING_USERNAME=your_username
AFRICASTALKING_API_KEY=your_api_key
AFRICASTALKING_SENDER_ID=your_sender_id

# File Upload Settings
MAX_UPLOAD_SIZE=10485760
ALLOWED_DOCUMENT_TYPES=pdf,jpg,jpeg,png

# Security
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Constituency Details
CONSTITUENCY_NAME=Your Constituency Name
CONSTITUENCY_CODE=001
CONSTITUENCY_EMAIL=info@constituency.go.ke
CONSTITUENCY_PHONE=+254700000000

# Admin Details
ADMIN_EMAIL=admin@constituency.go.ke
ADMIN_PHONE=+254700000001

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0